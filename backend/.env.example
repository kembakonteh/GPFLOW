# ─────────────────────────────────────────────────────────────────────────────
# GPFLOW — Backend Environment Variables
# Copy this file to .env and fill in real values before starting the server.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL DSN. Driver: asyncpg.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://gpflow:gpflow@localhost:5432/gpflow

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by ARQ for background job queues.
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# SECRET_KEY: generate with `openssl rand -hex 32`
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
# How long an access token is valid (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# How long a refresh token is valid (days)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Cloudflare R2 (S3-compatible object storage) ──────────────────────────────
# Found in Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=gpflow-uploads
# Public URL for serving files (enable public access on the bucket first)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Meta Developer Console → your app → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_permanent_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Stripe Dashboard → Developers → Webhooks → your endpoint → signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Application ───────────────────────────────────────────────────────────────
# Full URL of the React frontend (used for CORS and email links)
FRONTEND_URL=http://localhost:5173
# "dev" enables SQL echo, OpenAPI docs, debug tracebacks; "prod" disables them
ENVIRONMENT=dev
